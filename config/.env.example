# =============================================================================
# Environment Variables — Odoo + PostgreSQL Stack
# =============================================================================
# Copy to .env and fill in actual values:
#   cp .env.example .env
#   chmod 600 .env
#
# IMPORTANT: .env contains secrets. Never commit to git.
#
# PASSWORD RULES:
#   - Do NOT use $ (triggers variable interpolation) or backticks
#   - Do NOT wrap values in quotes (quotes are treated as literal characters)
#   - Safe special chars: ! ^ * % & # @
# =============================================================================

# PostgreSQL credentials
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=odoo

# Odoo admin master password (used for database management operations)
ODOO_ADMIN_PASSWORD=CHANGE_ME_use_a_different_strong_password

# =============================================================================
# Backup Offsite Sync — DO Spaces Credentials (BACK-02)
# =============================================================================
# These are Spaces-specific access keys, NOT the main DigitalOcean API token.
# Generate at: DigitalOcean Control Panel > API > Spaces Keys
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
SPACES_REGION=nyc3

# =============================================================================
# Email Notifications — SMTP Relay for Backup Failures (BACK-01)
# =============================================================================
# Any SMTP relay works: SendGrid, Mailgun, Gmail app password, Microsoft 365
# Password rules above apply to SMTP_PASSWORD as well.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USER=smtp_username
SMTP_PASSWORD=smtp_password
ALERT_EMAIL=admin@example.com
