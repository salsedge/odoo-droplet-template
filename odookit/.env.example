# =============================================================================
# OdooKit — Odoo automation and verification toolkit
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: Password values must NOT contain these characters unescaped:
#   $  (dollar sign)     — interpreted as variable reference
#   `  (backtick)        — interpreted as command substitution
#   "  (double quote)    — breaks quoting
#   '  (single quote)    — breaks quoting
#   \  (backslash)       — interpreted as escape character
# Use only alphanumeric characters and safe symbols: - _ . @ # % ^ & * + =
# =============================================================================

# -- Target Environment -------------------------------------------------------
LOCAL_ODOO_URL=http://localhost:8069
PROD_ODOO_URL=https://odoo.example.com

# -- Admin credentials (for setup/config tests) ------------------------------
ADMIN_LOGIN=admin@example.com
ADMIN_PASSWORD=CHANGE_ME

# -- Test user credentials (created by setup tests, used by workflow tests) ---
TEST_USER_LOGIN=testuser@example.com
TEST_USER_PASSWORD=CHANGE_ME

# -- Local staging database (must match docker-compose.yml) -------------------
LOCAL_POSTGRES_USER=odoo
LOCAL_POSTGRES_PASSWORD=odoo_local_dev
LOCAL_POSTGRES_DB=odoo

# -- Infrastructure audit SSH target ------------------------------------------
INFRA_SSH_HOST=
INFRA_SSH_PORT=9292
INFRA_SSH_USER=deploy
TUNNEL_LOCAL_PORT=8443

# -- Reporting ----------------------------------------------------------------
# Set to any value to generate HTML report instead of console output
REPORT=
