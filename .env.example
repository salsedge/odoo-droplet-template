# =============================================================================
# Project Root Environment Variables
# =============================================================================
# Copy to .env and fill in actual values:
#   cp .env.example .env
#   chmod 600 .env
#
# These are sourced locally for Terraform and Makefile operations.
# IMPORTANT: .env contains secrets. Never commit to git.
# =============================================================================

# DigitalOcean API Token (Terraform provider)
# Generate at: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=

# DigitalOcean Spaces Keys (Terraform state backend)
# Generate at: https://cloud.digitalocean.com/account/api/spaces
# These are DO Spaces keys, NOT AWS credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
